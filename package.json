{
  "name": "n8n-nodes-langfuse-studio",
  "version": "1.4.0",
  "description": "n8n community node for Langfuse ingestion and Public API access.",
  "license": "MIT",
  "author": {
    "name": "filip.benklewski"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FilipB97/n8n-langfuse.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "n8n-community-node-package",
    "langfuse",
    "observability",
    "llm"
  ],
  "main": "dist/index.js",
  "files": [
    "dist/index.js",
    "dist/index.d.ts",
    "dist/index.js.map",
    "dist/index.d.ts.map",
    "dist/src",
    "dist/nodes/Langfuse",
    "dist/credentials",
    "README.md",
    "CHANGELOG.md",
    "docs"
  ],
  "scripts": {
    "compile": "node ./scripts/clean-dist.mjs && tsc -p . && node ./scripts/copy-assets.mjs",
    "build": "npm run compile",
    "test": "tsx --test tests/**/*.test.ts",
    "lint": "tsc -p . --noEmit && eslint \"nodes/**/*.ts\" \"credentials/**/*.ts\"",
    "lint:fix": "eslint \"nodes/**/*.ts\" \"credentials/**/*.ts\" --fix",
    "dev": "npm run compile",
    "package": "npm run compile"
  },
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/LangfuseApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Langfuse/Langfuse.node.js"
    ]
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
